{
  "name": "clad0-desktop",
  "version": "1.0.0-alpha.1",
  "description": "clad0 as a standalone Chromium desktop app",
  "main": "electron/main.js",
  "author": "Matt Desgagne",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "server": "node clad0-server/server.js",
    "dist": "electron-builder --win nsis --x64",
    "dist:portable": "electron-builder --win portable --x64",
    "dist:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.fallenasylum.clad0",
    "productName": "clad0",
    "asar": true,
    "asarUnpack": [
      "clad0-server/**"
    ],
    "files": [
      "electron/**",
      "clad0-server/**",
      "!clad0-server/data/**",
      "!clad0-server/node_modules/**",
      "!clad0-server/**/*.bak*",
      "!clad0-server/**/*.backup-*",
      "README.md",
      "CHANGELOG.md",
      "LICENSE",
      "CUSTOM-THEMES.md",
      "BUILD-DESKTOP.md",
      "DESKTOP-SETTINGS-NOTES.md",
      "SHELL-VS-BROWSER.md",
      "EDITOR-FIELD-LAYOUT-NOTES.md"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  }
}
